<launch>
  <arg name="use_rf2o" default="true"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="odom_topic" default="/odom"/>
  <arg name="map_frame" default="map"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_footprint"/>
  <arg name="lidar_frame" default="lidar_frame"/>

  <!--
    MEASURE_REQUIRED: base_footprint -> lidar_frame translation and rotation.
    This publisher is disabled by default. Set every lidar_* argument to measured
    values before enabling it; the MEASURE_REQUIRED defaults are intentionally
    non-numeric so an unmeasured transform cannot silently run.
  -->
  <arg name="publish_lidar_tf" default="false"/>
  <arg name="lidar_x" default="MEASURE_REQUIRED"/>
  <arg name="lidar_y" default="MEASURE_REQUIRED"/>
  <arg name="lidar_z" default="MEASURE_REQUIRED"/>
  <arg name="lidar_yaw" default="MEASURE_REQUIRED"/>
  <arg name="lidar_pitch" default="MEASURE_REQUIRED"/>
  <arg name="lidar_roll" default="MEASURE_REQUIRED"/>

  <include file="$(find ros1_maze_escape)/launch/odometry.launch">
    <arg name="use_rf2o" value="$(arg use_rf2o)"/>
    <arg name="scan_topic" value="$(arg scan_topic)"/>
    <arg name="odom_topic" value="$(arg odom_topic)"/>
    <arg name="odom_frame" value="$(arg odom_frame)"/>
    <arg name="base_frame" value="$(arg base_frame)"/>
  </include>

  <group if="$(arg publish_lidar_tf)">
    <node pkg="tf2_ros"
          type="static_transform_publisher"
          name="base_to_lidar_measured_tf"
          args="$(arg lidar_x) $(arg lidar_y) $(arg lidar_z) $(arg lidar_yaw) $(arg lidar_pitch) $(arg lidar_roll) $(arg base_frame) $(arg lidar_frame)"/>
  </group>

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <rosparam command="load" file="$(find ros1_maze_escape)/config/gmapping.yaml"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="odom_frame" value="$(arg odom_frame)"/>
    <param name="map_frame" value="$(arg map_frame)"/>
    <remap from="scan" to="$(arg scan_topic)"/>
  </node>
</launch>

