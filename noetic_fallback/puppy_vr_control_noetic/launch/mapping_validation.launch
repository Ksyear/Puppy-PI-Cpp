<launch>
  <arg name="output_dir"/>
  <arg name="duration_sec" default="120.0"/>
  <arg name="stationary_sec" default="20.0"/>
  <arg name="snapshot_period_sec" default="5.0"/>
  <arg name="expect_return" default="false"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="map_size_m" default="12.0"/>
  <arg name="resolution" default="0.05"/>
  <arg name="laser_yaw" default="0.0"/>
  <arg name="min_range" default="0.15"/>
  <arg name="max_range" default="8.0"/>
  <arg name="base_frame" default="base_footprint"/>

  <!-- 이 launch는 지도작성만 검증한다. 자율주행 노드는 실행하지 않는다. -->
  <node name="lidar_mapping" pkg="puppy_vr_control_noetic"
        type="lidar_mapping.py" output="screen" required="true">
    <param name="scan_topic" value="$(arg scan_topic)"/>
    <param name="map_size_m" value="$(arg map_size_m)"/>
    <param name="resolution" value="$(arg resolution)"/>
    <param name="laser_yaw" value="$(arg laser_yaw)"/>
    <param name="min_range" value="$(arg min_range)"/>
    <param name="max_range" value="$(arg max_range)"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="map_save_path" value="$(arg output_dir)"/>
    <param name="map_name" value="mapper_final_map"/>
    <param name="pose_topic" value="/lidar_mapping/pose"/>
    <param name="publish_tf" value="true"/>
  </node>

  <node name="mapping_run_recorder" pkg="puppy_vr_control_noetic"
        type="mapping_run_recorder.py" output="screen" required="true">
    <param name="output_dir" value="$(arg output_dir)"/>
    <param name="duration_sec" value="$(arg duration_sec)"/>
    <param name="stationary_sec" value="$(arg stationary_sec)"/>
    <param name="snapshot_period_sec" value="$(arg snapshot_period_sec)"/>
    <param name="expect_return" value="$(arg expect_return)"/>
    <param name="scan_topic" value="$(arg scan_topic)"/>
    <param name="filter_min_range" value="$(arg min_range)"/>
    <param name="filter_max_range" value="$(arg max_range)"/>
    <param name="base_frame" value="$(arg base_frame)"/>
  </node>

  <node name="mapping_validation_bag" pkg="rosbag" type="record"
        output="screen"
        args="-O $(arg output_dir)/run.bag $(arg scan_topic) /map /lidar_mapping/pose /tf /tf_static /rosout /cmd_vel /cmd_vel_nav /puppy_control/velocity /puppy_control/velocity/autogait /imu /imu/data"/>
</launch>
