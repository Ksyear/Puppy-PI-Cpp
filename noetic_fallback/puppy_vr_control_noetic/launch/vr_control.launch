<launch>
  <!-- [비상용 3안] ROS1 Noetic 이미지에서 VR 조종+영상+상태 전송 -->
  <!-- 사전 조건: 로봇 기본 노드(puppy_control 등, 부팅 자동실행) + 카메라:
       roslaunch puppy_bringup usb_cam.launch -->
  <arg name="use_camera" default="true"/>
  <arg name="debug" default="false"/>
  <arg name="stand_on_start" default="true"/>   <!-- 시작 시 다리 펴고 서기 -->
  <arg name="image_topic" default=""/>          <!-- '' = 압축 영상 토픽 자동 탐지 -->

  <node name="vr_udp_teleop" pkg="puppy_vr_control_noetic" type="vr_udp_teleop.py" output="screen">
    <param name="debug" value="$(arg debug)"/>
    <param name="stand_on_start" value="$(arg stand_on_start)"/>
  </node>

  <node if="$(arg use_camera)" name="camera_udp_sender" pkg="puppy_vr_control_noetic"
        type="camera_udp_sender.py" output="screen">
    <param name="image_topic" value="$(arg image_topic)"/>
  </node>

  <node name="robot_status_sender" pkg="puppy_vr_control_noetic"
        type="robot_status_sender.py" output="screen"/>
</launch>
